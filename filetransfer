#!/usr/bin/env python3
import os, sys, runpy, subprocess, shutil

DIR = os.path.dirname(os.path.abspath(__file__))


def run(cmd, **kwargs):
    return subprocess.run(cmd, **kwargs)


def ensure_brew():
    if not shutil.which("brew"):
        print("  Installing Homebrew…")
        result = run(
            ["/bin/bash", "-c",
             "curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh | bash"]
        )
        if result.returncode != 0 or not shutil.which("brew"):
            print("  ❌ Homebrew install failed. Install it manually from https://brew.sh")
            sys.exit(1)
    else:
        print("  Updating Homebrew…")
        run(["brew", "update"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def ensure_python():
    # Only upgrade if Python was installed via Homebrew — never touch the system Python
    result = run(["brew", "list", "--formula", "python3"],
                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if result.returncode == 0:
        print("  Updating python3…")
        run(["brew", "upgrade", "python3"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    else:
        result = run(["brew", "list", "--formula", "python"],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if result.returncode == 0:
            print("  Updating python…")
            run(["brew", "upgrade", "python"],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        # else: system Python, leave it alone


def ensure_adb():
    if shutil.which("adb"):
        print("  Updating adb…")
        run(["brew", "upgrade", "android-platform-tools"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    else:
        print("  Installing adb…")
        run(["brew", "install", "android-platform-tools"])


def main():
    print("\n  📡 FileTransfer — checking dependencies…")

    ensure_brew()
    ensure_python()
    ensure_adb()

    print("  ✅ Dependencies ready\n")

    os.chdir(DIR)
    sys.argv = [os.path.join(DIR, "server.py")] + sys.argv[1:]
    runpy.run_path(os.path.join(DIR, "server.py"), run_name="__main__")


main()
