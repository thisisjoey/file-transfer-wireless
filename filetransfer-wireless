#!/bin/bash
# filetransfer-wireless — single executable, installs everything and starts the server.
# Works on any Mac with macOS 10.15+.
set -e

HERE="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# ── Python 3 ──────────────────────────────────────────────────────────────────
PYTHON=""
for candidate in python3 python; do
  if command -v "$candidate" &>/dev/null; then
    ver=$("$candidate" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+' | head -1)
    major="${ver%%.*}"
    if [ "$major" -ge 3 ] 2>/dev/null; then
      PYTHON="$candidate"
      break
    fi
  fi
done

if [ -z "$PYTHON" ]; then
  echo ""
  echo "  ✗ Python 3 is required but not found."
  echo "  Install it from https://www.python.org/downloads/ then run again."
  echo ""
  # Try to open the download page
  open "https://www.python.org/downloads/" 2>/dev/null || true
  exit 1
fi

# ── Homebrew ──────────────────────────────────────────────────────────────────
if ! command -v brew &>/dev/null; then
  # Add common Homebrew paths in case it's installed but not in PATH
  export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
fi

if ! command -v brew &>/dev/null; then
  echo "  📦 Installing Homebrew…"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
fi

# ── adb ───────────────────────────────────────────────────────────────────────
if ! command -v adb &>/dev/null; then
  echo "  📦 Installing adb (Android Debug Bridge)…"
  brew install android-platform-tools
fi

# ── qrcode Python library ─────────────────────────────────────────────────────
if ! "$PYTHON" -c "import qrcode.image.svg" 2>/dev/null; then
  echo "  📦 Installing qrcode library…"
  "$PYTHON" -m pip install --quiet "qrcode[svg]"
fi

# ── Launch ────────────────────────────────────────────────────────────────────
PORT="${1:-8765}"
exec "$PYTHON" "$HERE/server.py" "$PORT"
